<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>Label</key>
		<string>com.jibidus.homebrew-updater</string>

		<key>Program</key>
		<string>/bin/bash</string>

		<key>ProgramArguments</key>
		<array>
			<string>${script_folder}/homebrew-updater.bash</string>
		</array>

		<key>StandardOutPath</key>
		<string>/var/log/homebrew-updater.log</string>

		<key>StandardErrorPath</key>
		<string>/var/log/homebrew-updater.error.log</string>

		<key>StartCalendarInterval</key>
    <dict>
        <key>Minute</key>
        <integer>00</integer>
        <key>Hour</key>
        <integer>13</integer>
    </dict>

		<key>KeepAlive</key>
		<false/>

		<key>ProcessType</key>
		<string>Background</string>
	</dict>
</plist>
